---
import { useTranslations, localePath, type Lang } from '@utils/i18n';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);

const stats = [
  { value: '50+', target: 50, suffix: '+', key: 'hero.stats.articles' as const },
  { value: '12', target: 12, suffix: '', key: 'hero.stats.projects' as const },
  { value: '3+', target: 3, suffix: '+', key: 'hero.stats.years' as const },
];
---

<section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden">
  <!-- Background effects -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-brand-600/20 rounded-full blur-[120px]"></div>
    <div class="absolute top-1/4 right-1/4 w-[400px] h-[400px] bg-neon-cyan/10 rounded-full blur-[100px]"></div>
    <div class="absolute bottom-1/4 left-1/4 w-[300px] h-[300px] bg-neon-purple/10 rounded-full blur-[80px]"></div>

    <div class="absolute inset-0 scanlines opacity-30"></div>

    <div class="hero-particle absolute top-[20%] left-[15%] w-1 h-1 bg-neon-cyan rounded-full opacity-60"></div>
    <div class="hero-particle absolute top-[30%] right-[20%] w-1.5 h-1.5 bg-neon-purple rounded-full opacity-50"></div>
    <div class="hero-particle absolute bottom-[30%] left-[25%] w-1 h-1 bg-brand-400 rounded-full opacity-40"></div>
    <div class="hero-particle absolute top-[60%] right-[15%] w-2 h-2 bg-neon-cyan rounded-full opacity-30"></div>
    <div class="hero-particle absolute bottom-[20%] right-[30%] w-1 h-1 bg-neon-pink rounded-full opacity-50"></div>
  </div>

  <!-- Content -->
  <div class="hero-content relative z-10 max-w-5xl mx-auto px-6 text-center">
    <!-- Greeting tag -->
    <div id="hero-greeting" class="hero-reveal inline-flex items-center gap-2 px-4 py-2 mb-8 rounded-full border border-neon-cyan/30 bg-neon-cyan/5" data-cursor-magnetic>
      <span class="w-2 h-2 bg-neon-cyan rounded-full animate-pulse"></span>
      <span class="text-sm font-mono text-neon-cyan tracking-wider">{t('hero.greeting')}</span>
    </div>

    <!-- Main title -->
    <h1 id="hero-title" class="hero-reveal mb-6">
      <span id="hero-title-line1" class="block text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-display font-black tracking-tight text-white leading-none">
        {t('hero.title')}
      </span>
      <span id="hero-title-line2" class="block text-6xl sm:text-7xl md:text-8xl lg:text-9xl font-display font-black tracking-tight leading-none mt-2">
        <span class="gradient-text">{t('hero.titleHighlight')}</span>
      </span>
    </h1>

    <!-- Subtitle -->
    <p id="hero-subtitle" class="hero-reveal max-w-2xl mx-auto text-lg sm:text-xl text-gray-400 leading-relaxed mb-10">
      {t('hero.subtitle')}
    </p>

    <!-- CTA Buttons -->
    <div id="hero-cta" class="hero-reveal flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
      <a
        href={localePath(lang, '/blog')}
        class="hero-btn group relative inline-flex items-center gap-2 px-8 py-4 font-semibold text-sm tracking-wide rounded-xl
               bg-gradient-to-r from-brand-500 to-brand-600
               text-white shadow-[0_0_30px_rgba(99,102,241,0.3)]
               hover:shadow-[0_0_40px_rgba(99,102,241,0.5)]
               transition-all duration-300"
        data-cursor-magnetic
      >
        <span>{t('hero.cta1')}</span>
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>

      <a
        href={localePath(lang, '/portfolio')}
        class="hero-btn group relative inline-flex items-center gap-2 px-8 py-4 font-semibold text-sm tracking-wide rounded-xl
               border border-white/20 text-white
               hover:border-neon-cyan/50 hover:bg-neon-cyan/5 hover:text-neon-cyan
               hover:shadow-[0_0_30px_rgba(0,245,255,0.15)]
               transition-all duration-300"
        data-cursor-magnetic
      >
        <span>{t('hero.cta2')}</span>
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
        </svg>
      </a>
    </div>

    <!-- Stats -->
    <div id="hero-stats" class="hero-reveal flex items-center justify-center gap-8 sm:gap-16">
      {stats.map((stat) => (
        <div class="text-center">
          <div class="text-2xl sm:text-3xl font-display font-bold text-white" data-counter-target={stat.target} data-counter-suffix={stat.suffix}>
            {stat.value}
          </div>
          <div class="text-xs sm:text-sm font-mono text-gray-500 mt-1">{t(stat.key)}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- Scroll indicator -->
  <div id="hero-scroll" class="hero-reveal absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2">
    <span class="text-xs font-mono text-gray-500 tracking-widest uppercase">{t('hero.scroll')}</span>
    <div class="w-5 h-8 border-2 border-gray-600 rounded-full flex justify-center">
      <div class="w-1 h-2 bg-neon-cyan rounded-full mt-1.5 animate-bounce"></div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import {
    splitTextIntoChars,
    magneticHover,
    animateCounter,
  } from '@utils/animations';

  gsap.registerPlugin(ScrollTrigger);

  let ctx: gsap.Context | null = null;

  function initHeroAnimations() {
    // Clean previous instance (specific to Hero, no global kills)
    ctx?.revert();
    ctx = gsap.context(() => {
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const isDesktop = window.matchMedia('(min-width: 768px)').matches;

      // If reduce motion, just ensure visible and return
      if (reduceMotion) {
        gsap.set('.hero-reveal, .split-char', { clearProps: 'all', autoAlpha: 1 });
        return;
      }

      // ─── Title character split (desktop only) ───
      let line1Chars: HTMLSpanElement[] = [];
      let line2Chars: HTMLSpanElement[] = [];

      if (isDesktop) {
        const line1 = document.getElementById('hero-title-line1');
        const line2 = document.querySelector('#hero-title-line2 .gradient-text');
        if (line1) line1Chars = splitTextIntoChars(line1);
        if (line2) line2Chars = splitTextIntoChars(line2);
      }

      // ─── Build a single timeline with ALL reveals ───
      const tl = gsap.timeline({
        defaults: { ease: 'power3.out' },
        onComplete: () => {
          // Make sure chars stay visible after animation
          gsap.set(['.hero-reveal', '.split-char'], { clearProps: 'transform' });
        },
      });

      tl.from('#hero-greeting', { autoAlpha: 0, y: 20, scale: 0.9, duration: 0.6 });

      if (isDesktop && line1Chars.length > 0) {
        tl.from(line1Chars, {
          autoAlpha: 0,
          y: 'random(40, 100)',
          rotation: 'random(-90, 90)',
          stagger: 0.025,
          duration: 0.7,
        }, '-=0.3');
      } else {
        tl.from('#hero-title', { autoAlpha: 0, y: 40, duration: 0.7 }, '-=0.3');
      }

      if (isDesktop && line2Chars.length > 0) {
        tl.from(line2Chars, {
          autoAlpha: 0,
          y: 'random(20, 80)',
          scale: 0.3,
          stagger: 0.03,
          duration: 0.8,
          ease: 'back.out(1.7)',
        }, '<0.1');
      }

      tl.from('#hero-subtitle', { autoAlpha: 0, y: 30, duration: 0.6 }, '-=0.4');
      tl.from('#hero-cta a', {
        autoAlpha: 0,
        y: 20,
        scale: 0.95,
        stagger: 0.15,
        duration: 0.5,
      }, '-=0.3');
      tl.from('#hero-stats > div', {
        autoAlpha: 0,
        y: 20,
        stagger: 0.1,
        duration: 0.5,
      }, '-=0.3');
      tl.from('#hero-scroll', { autoAlpha: 0, duration: 0.5 }, '-=0.2');

      // Count-up stats (added to the same timeline)
      if (!reduceMotion) {
        tl.add(() => {
          const els = document.querySelectorAll<HTMLElement>('#hero-stats [data-counter-target]');
          els.forEach((el) => {
            const target = parseInt(el.dataset.counterTarget || '0', 10);
            const suffix = el.dataset.counterSuffix || '';
            animateCounter(el, target, suffix);
          });
        }, '<0.2');
      }

      // ─── Particles loop (only after main timeline starts) ───
      tl.add(() => {
        gsap.to('.hero-particle', {
          y: 'random(-20, 20)',
          x: 'random(-10, 10)',
          rotation: 'random(-180, 180)',
          duration: 'random(3, 5)',
          repeat: -1,
          yoyo: true,
          ease: 'sine.inOut',
          stagger: { each: 0.5, from: 'random' },
        });
      }, '<'); // parallel with the rest

      // ─── Desktop-only extras (parallax + magnetic) ───
      if (isDesktop) {
        const content = document.querySelector<HTMLElement>('.hero-content');
        if (content) {
          const xTo = gsap.quickTo(content, 'x', { duration: 0.6, ease: 'power2.out' });
          const yTo = gsap.quickTo(content, 'y', { duration: 0.6, ease: 'power2.out' });
          const onMove = (e: MouseEvent) => {
            xTo((e.clientX / window.innerWidth - 0.5) * 20);
            yTo((e.clientY / window.innerHeight - 0.5) * 20);
          };
          window.addEventListener('mousemove', onMove);
          ctx!.add(() => window.removeEventListener('mousemove', onMove));
        }

        magneticHover('.hero-btn', { strength: 0.25, duration: 0.4 });
      }
    });
  }

  function bootOnce() {
    if ((window as any).__heroAnimationsBooted) return;
    (window as any).__heroAnimationsBooted = true;
    initHeroAnimations();
  }

  document.addEventListener('DOMContentLoaded', bootOnce);
  document.addEventListener('astro:page-load', () => {
    (window as any).__heroAnimationsBooted = false;
    bootOnce();
  });
</script>
