---
import { getCollection } from 'astro:content';
import { useTranslations, localePath, type Lang } from '@utils/i18n';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);

const posts = await getCollection('posts', ({ id, data }) => {
  return id.startsWith(`${lang}/`) && data.language === lang && !data.draft;
});

const sortedPosts = posts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((post) => ({
    slug: post.id.replace(`${lang}/`, '').replace(/\.(md|mdx)$/, ''),
    title: post.data.title,
    description: post.data.description,
    tags: post.data.tags,
    category: post.data.category,
    date: post.data.pubDate.toISOString(),
  }));
---

<section class="max-w-4xl mx-auto px-6 py-16">
  <!-- Header -->
  <div class="mb-10">
    <div class="flex items-center gap-3 mb-4">
      <div class="w-8 h-[2px] bg-neon-cyan"></div>
      <span class="text-xs font-mono text-neon-cyan tracking-[0.3em] uppercase">{t('search.pageTitle')}</span>
    </div>
    <h2 class="text-3xl sm:text-4xl font-display font-bold text-white">
      {t('search.pageTitle')} <span class="gradient-text">{t('search.pageTitleHighlight')}</span>
    </h2>
  </div>

  <!-- Search Input -->
  <div class="search-input-wrapper relative mb-8">
    <div class="relative group">
      <div class="absolute -inset-1 bg-gradient-to-r from-neon-cyan/20 via-brand-500/20 to-neon-purple/20 rounded-2xl blur-lg opacity-0 group-focus-within:opacity-100 transition-opacity duration-500"></div>

      <div class="relative flex items-center
                  bg-[#111827]/80 backdrop-blur-xl
                  border border-white/10 rounded-2xl
                  group-focus-within:border-neon-cyan/40
                  transition-all duration-300">
        <div class="flex items-center justify-center w-14 h-14 border-r border-white/10">
          <svg class="w-5 h-5 text-neon-cyan/70 group-focus-within:text-neon-cyan transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/>
          </svg>
        </div>

        <input
          type="text"
          id="search-input"
          placeholder={t('search.placeholder')}
          class="w-full bg-transparent px-5 py-4
                 text-white placeholder-gray-500
                 font-mono text-sm
                 focus:outline-none"
          autocomplete="off"
          spellcheck="false"
        />

        <div class="hidden sm:flex items-center gap-1 pr-4">
          <kbd class="px-2 py-0.5 text-[10px] font-mono text-gray-500 bg-white/5 border border-white/10 rounded">
            /
          </kbd>
        </div>
      </div>
    </div>
  </div>

  <!-- Results counter -->
  <div id="search-counter" class="mb-6 opacity-0 transition-opacity duration-200">
    <span class="text-sm font-mono text-gray-500">
      <span id="result-count">0</span> {t('search.resultCount')}(s)
    </span>
  </div>

  <!-- Results Grid -->
  <div id="search-results" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    {sortedPosts.map((post) => (
      <a
        href={localePath(lang, `/blog/${post.slug}`)}
        class="search-result-card group relative flex flex-col
               bg-[#111827]/60 backdrop-blur-sm
               border border-white/[0.06] rounded-xl p-5
               hover:border-neon-cyan/20
               hover:shadow-[0_0_30px_rgba(0,245,255,0.05)]
               transition-all duration-300"
        data-title={post.title.toLowerCase()}
        data-description={post.description.toLowerCase()}
        data-tags={post.tags.join(' ').toLowerCase()}
      >
        <div class="absolute top-0 left-0 right-0 h-[1px] bg-gradient-to-r from-transparent via-neon-cyan/30 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>

        <div class="flex items-center justify-between mb-3">
          <span class:list={[
            'px-2 py-0.5 text-[10px] font-mono font-bold tracking-widest rounded border',
            post.category === 'tech' && 'text-neon-cyan border-neon-cyan/30 bg-neon-cyan/5',
            post.category === 'gaming' && 'text-neon-purple border-neon-purple/30 bg-neon-purple/5',
            post.category === 'devlog' && 'text-neon-pink border-neon-pink/30 bg-neon-pink/5',
          ]}>
            {post.category.toUpperCase()}
          </span>
          <time class="text-[11px] font-mono text-gray-500">
            {new Date(post.date).toLocaleDateString(lang === 'es' ? 'es-ES' : 'en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
          </time>
        </div>

        <h3 class="text-base font-display font-bold text-white mb-2 leading-snug
                    group-hover:text-neon-cyan transition-colors">
          {post.title}
        </h3>

        <p class="text-sm text-gray-400 leading-relaxed mb-4 line-clamp-2 flex-1">
          {post.description}
        </p>

        <div class="flex flex-wrap gap-1.5 mb-3">
          {post.tags.slice(0, 3).map((tag) => (
            <span class="px-1.5 py-0.5 text-[10px] font-mono text-gray-500 bg-white/5 rounded border border-white/5">
              #{tag}
            </span>
          ))}
        </div>

        <div class="flex items-center gap-1.5 text-xs font-medium text-gray-500 group-hover:text-neon-cyan transition-colors">
          <span>{t('search.readMore')}</span>
          <svg class="w-3 h-3 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </div>
      </a>
    ))}
  </div>

  <!-- No results message -->
  <div id="no-results" class="hidden text-center py-16">
    <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-white/5 mb-4">
      <svg class="w-8 h-8 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/>
      </svg>
    </div>
    <p class="text-lg font-display font-semibold text-white mb-2">{t('search.noResults')}</p>
    <p class="text-sm text-gray-500">{t('search.noResultsHint')}</p>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { animateCounterTo } from '@utils/animations';

  if (!window.__searchKeyHandler) {
    window.__searchKeyHandler = null;
  }

  function initSearch() {
    const input = document.getElementById('search-input');
    const results = document.querySelectorAll('.search-result-card');
    const counter = document.getElementById('search-counter');
    const countSpan = document.getElementById('result-count') as HTMLElement | null;
    const noResults = document.getElementById('no-results');

    if (!input || !countSpan) return;

    function shakeNoResults() {
      if (!noResults) return;
      gsap.fromTo(
        noResults,
        { x: -8 },
        { x: 0, duration: 0.5, ease: 'elastic.out(1, 0.4)' }
      );
    }

    function performSearch(query: string) {
      const q = query.toLowerCase().trim();
      let visibleCount = 0;

      results.forEach((card, i) => {
        const title = card.getAttribute('data-title') || '';
        const description = card.getAttribute('data-description') || '';
        const tags = card.getAttribute('data-tags') || '';

        const matches = q === '' ||
          title.includes(q) ||
          description.includes(q) ||
          tags.includes(q);

        if (matches) {
          card.style.display = '';
          if (q !== '') {
            gsap.fromTo(
              card,
              { autoAlpha: 0, y: 12, scale: 0.96 },
              {
                autoAlpha: 1,
                y: 0,
                scale: 1,
                duration: 0.5,
                delay: i * 0.03,
                ease: 'power3.out',
              }
            );
          } else {
            gsap.set(card, { autoAlpha: 1, y: 0, scale: 1 });
          }
          visibleCount++;
        } else {
          gsap.to(card, {
            autoAlpha: 0,
            y: 8,
            scale: 0.96,
            duration: 0.25,
            onComplete: () => { card.style.display = 'none'; },
          });
        }
      });

      if (q !== '') {
        counter.style.opacity = '1';
        animateCounterTo(countSpan, visibleCount);
      } else {
        counter.style.opacity = '0';
      }

      if (visibleCount === 0 && q !== '') {
        noResults?.classList.remove('hidden');
        shakeNoResults();
      } else {
        noResults?.classList.add('hidden');
      }
    }

    const newInput = input.cloneNode(true);
    input.parentNode?.replaceChild(newInput, input);

    newInput.addEventListener('input', (e) => {
      performSearch((e.target as HTMLInputElement).value);
    });

    if (window.__searchKeyHandler) {
      document.removeEventListener('keydown', window.__searchKeyHandler);
    }

    window.__searchKeyHandler = (e: KeyboardEvent) => {
      if (e.key === '/' && document.activeElement?.tagName !== 'INPUT') {
        e.preventDefault();
        (newInput as HTMLInputElement).focus();
      }
      if (e.key === 'Escape' && document.activeElement === newInput) {
        (newInput as HTMLInputElement).blur();
        (newInput as HTMLInputElement).value = '';
        performSearch('');
      }
    };

    document.addEventListener('keydown', window.__searchKeyHandler);
  }

  document.addEventListener('DOMContentLoaded', initSearch);
  document.addEventListener('astro:page-load', initSearch);
</script>
