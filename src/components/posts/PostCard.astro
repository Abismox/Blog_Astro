---
interface Props {
  title: string;
  description: string;
  date: string;
  tags: string[];
  category: string;
  url: string;
  index?: number;
  readMoreLabel?: string;
}

const {
  title,
  description,
  date,
  tags,
  category,
  url,
  index = 0,
  readMoreLabel = 'Leer más',
} = Astro.props;

const categoryColors: Record<string, string> = {
  tech: 'text-neon-cyan border-neon-cyan/30 bg-neon-cyan/5',
  gaming: 'text-neon-purple border-neon-purple/30 bg-neon-purple/5',
  devlog: 'text-neon-pink border-neon-pink/30 bg-neon-pink/5',
};

const categoryLabels: Record<string, string> = {
  tech: 'TECH',
  gaming: 'GAMING',
  devlog: 'DEVLOG',
};
---

<article
  class="post-card group relative flex flex-col
         bg-[#111827]/60 backdrop-blur-sm
         border border-white/[0.06]
         rounded-2xl overflow-hidden
         hover:border-neon-cyan/20
         hover:shadow-[0_0_40px_rgba(0,245,255,0.06)]
         transition-all duration-500 ease-out"
  style={`--stagger-delay: ${index * 0.1}s`}
  data-cursor-tilt
>
  <!-- Top accent line -->
  <div class="absolute top-0 left-0 right-0 h-[1px] bg-gradient-to-r from-transparent via-neon-cyan/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

  <!-- Content -->
  <div class="flex flex-col flex-1 p-6">
    <!-- Category + Date -->
    <div class="flex items-center justify-between mb-4">
      <span class:list={[
        'px-2.5 py-1 text-[10px] font-mono font-bold tracking-widest rounded-md border',
        categoryColors[category] || categoryColors.tech,
      ]}>
        {categoryLabels[category] || 'TECH'}
      </span>
      <time class="text-xs font-mono text-gray-500">{date}</time>
    </div>

    <!-- Title -->
    <h3 class="text-lg font-display font-bold text-white mb-3 leading-snug
               group-hover:text-neon-cyan transition-colors duration-300">
      {title}
    </h3>

    <!-- Description -->
    <p class="text-sm text-gray-400 leading-relaxed mb-5 flex-1 line-clamp-3">
      {description}
    </p>

    <!-- Tags -->
    <div class="flex flex-wrap gap-2 mb-5">
      {tags.slice(0, 3).map((tag) => (
        <span class="px-2 py-0.5 text-[10px] font-mono text-gray-500 bg-white/5 rounded-md border border-white/5">
          #{tag}
        </span>
      ))}
    </div>

    <!-- Read more link -->
    <a
      href={url}
      class="inline-flex items-center gap-2 text-sm font-medium text-gray-400
             group-hover:text-neon-cyan transition-colors duration-300"
    >
      <span>{readMoreLabel}</span>
      <svg
        class="w-4 h-4 group-hover:translate-x-1.5 transition-transform duration-300"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
      </svg>
    </a>
  </div>

  <!-- Hover glow effect -->
  <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none
              bg-gradient-to-b from-neon-cyan/[0.02] to-transparent"></div>
</article>
