---
import { useTranslations, type Lang } from '@utils/i18n';
import { games } from '@utils/games';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const t = useTranslations(lang);
---

<section class="relative py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="lobby-header mb-16">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-8 h-[2px] bg-neon-purple"></div>
        <span class="text-xs font-mono text-neon-purple tracking-[0.3em] uppercase">
          {t('arcade.sectionTitle')}
        </span>
      </div>
      <h2 class="lobby-title text-3xl sm:text-4xl md:text-5xl font-display font-bold text-white mb-4">
        {t('arcade.sectionTitle')} <span class="gradient-text">{t('arcade.sectionHighlight')}</span>
      </h2>
      <p class="text-gray-400 text-lg max-w-xl">{t('arcade.sectionSubtitle')}</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 cards-perspective">
      {games.map((game, i) => {
        const colorMap = {
          cyan: {
            border: 'hover:border-neon-cyan/40',
            glow: 'hover:shadow-[0_0_50px_rgba(0,245,255,0.12)]',
            accent: 'bg-neon-cyan',
            accentHex: '#00f5ff',
            text: 'text-neon-cyan',
            tag: 'border-neon-cyan/30 bg-neon-cyan/5',
            backBg: 'bg-gradient-to-br from-neon-cyan/20 via-brand-900/40 to-black',
            backText: 'text-neon-cyan',
          },
          purple: {
            border: 'hover:border-neon-purple/40',
            glow: 'hover:shadow-[0_0_50px_rgba(191,0,255,0.12)]',
            accent: 'bg-neon-purple',
            accentHex: '#bf00ff',
            text: 'text-neon-purple',
            tag: 'border-neon-purple/30 bg-neon-purple/5',
            backBg: 'bg-gradient-to-br from-neon-purple/20 via-brand-900/40 to-black',
            backText: 'text-neon-purple',
          },
          pink: {
            border: 'hover:border-neon-pink/40',
            glow: 'hover:shadow-[0_0_50px_rgba(255,0,255,0.12)]',
            accent: 'bg-neon-pink',
            accentHex: '#ff00ff',
            text: 'text-neon-pink',
            tag: 'border-neon-pink/30 bg-neon-pink/5',
            backBg: 'bg-gradient-to-br from-neon-pink/20 via-brand-900/40 to-black',
            backText: 'text-neon-pink',
          },
        };
        const c = colorMap[game.color];

        return (
          <div
            class={`card-3d game-card group relative
                    bg-[#0a0e1a] rounded-2xl border border-white/[0.06]
                    aspect-[3/4] min-h-[360px]
                    ${c.border} ${c.glow}
                    transition-shadow duration-500`}
            style={`--stagger-delay: ${i * 0.1}s`}
            data-flip-card
            data-cursor-tilt
            aria-label={`Flip ${game.title} card`}
          >
            <!-- FRONT FACE -->
            <div class="card-face card-face-front absolute inset-0 flex flex-col overflow-hidden rounded-2xl">
              <div class="relative aspect-video bg-[#050510] overflow-hidden">
                <div class="absolute inset-0 bg-[repeating-linear-gradient(0deg,transparent,transparent_2px,rgba(0,0,0,0.2)_2px,rgba(0,0,0,0.2)_4px)] pointer-events-none z-10"></div>

                <div class="absolute inset-0 flex items-center justify-center">
                  <div class={`w-20 h-20 rounded-full ${c.accent}/10 flex items-center justify-center`}>
                    <svg class={`w-10 h-10 ${c.text}/50`} fill="currentColor" viewBox="0 0 24 24">
                      <path d="M8 5v14l11-7z"/>
                    </svg>
                  </div>
                </div>

                <div class="absolute top-3 left-3 flex gap-1.5">
                  <span class={`w-1.5 h-1.5 rounded-full ${c.accent}/60 animate-pulse`}></span>
                  <span class={`w-1.5 h-1.5 rounded-full ${c.accent}/40 animate-pulse`} style="animation-delay: 0.5s"></span>
                </div>

                <div class="absolute top-3 right-3 px-2 py-0.5 rounded-md bg-black/60 border border-white/10 text-[9px] font-mono text-gray-400 tracking-widest uppercase">
                  Click ↻
                </div>
              </div>

              <div class="flex-1 p-5 flex flex-col">
                <div class="flex items-start justify-between mb-3">
                  <h3 class="font-display text-lg font-bold text-white group-hover:text-neon-cyan transition-colors">
                    {game.title}
                  </h3>
                  <span class="text-[10px] font-mono text-gray-600 uppercase tracking-wider">
                    #{String(i + 1).padStart(2, '0')}
                  </span>
                </div>

                <p class="text-sm text-gray-500 mb-4 line-clamp-2 flex-1">{game.description}</p>

                <div class="flex flex-wrap gap-2">
                  {game.tags.map((tag) => (
                    <span class={`px-2 py-0.5 text-[10px] font-mono ${c.text}/70 ${c.tag} rounded border`}>
                      {t(`arcade.tags.${tag}` as `arcade.tags.${string}`)}
                    </span>
                  ))}
                </div>
              </div>
            </div>

            <!-- BACK FACE -->
            <div class={`card-face card-face-back ${c.backBg} rounded-2xl border border-white/10 p-6 flex flex-col justify-between overflow-hidden`}>
              <div>
                <div class="flex items-center justify-between mb-4">
                  <h3 class={`font-display text-xl font-bold ${c.backText}`}>{game.title}</h3>
                  <button
                    type="button"
                    class="w-8 h-8 rounded-lg border border-white/10 flex items-center justify-center text-gray-400 hover:text-white hover:border-white/30 transition-all"
                    aria-label="Flip back"
                    data-flip-back
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12a9 9 0 0115 6.7L21 16M3 12a9 9 0 0115-6.7L21 8M21 3v5h-5M3 21v-5h5"/>
                    </svg>
                  </button>
                </div>

                <p class="text-sm text-gray-300 mb-6 leading-relaxed">{game.description}</p>

                {game.controls && (
                  <div class="mb-4">
                    <div class="text-[10px] font-mono text-gray-500 tracking-[0.2em] uppercase mb-2">Controls</div>
                    <div class="flex flex-wrap gap-2">
                      {game.controls.map((ctrl) => (
                        <span class={`px-2 py-0.5 text-[10px] font-mono ${c.text} border ${c.tag} rounded`}>
                          {ctrl}
                        </span>
                      ))}
                    </div>
                  </div>
                )}

                {game.tech && (
                  <div class="mb-4">
                    <div class="text-[10px] font-mono text-gray-500 tracking-[0.2em] uppercase mb-2">Stack</div>
                    <div class="flex flex-wrap gap-2">
                      {game.tech.map((tech) => (
                        <span class="px-2 py-0.5 text-[10px] font-mono text-gray-300 bg-white/5 border border-white/10 rounded">
                          {tech}
                        </span>
                      ))}
                    </div>
                  </div>
                )}
              </div>

              <div class="flex items-center justify-between text-[10px] font-mono text-gray-500 tracking-wider">
                {game.year && <span>© {game.year}</span>}
                {game.repoUrl && (
                  <a
                    href={game.repoUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class={`${c.text} hover:underline flex items-center gap-1`}
                    onclick="event.stopPropagation()"
                  >
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                    </svg>
                    SOURCE
                  </a>
                )}
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import {
    splitTextIntoChars,
    tilt3D,
  } from '@utils/animations';

  gsap.registerPlugin(ScrollTrigger);

  let ctx: gsap.Context | null = null;

  function initLobby() {
    ctx?.revert();
    ctx = gsap.context(() => {
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const isDesktop = window.matchMedia('(min-width: 768px)').matches;

      if (reduceMotion) {
        gsap.set(['.lobby-header', '.game-card'], { clearProps: 'all', autoAlpha: 1 });
        return;
      }

      gsap.set(['.lobby-header', '.game-card'], { autoAlpha: 0 });
      gsap.set('.lobby-header', { y: 40 });
      gsap.set('.game-card', { y: 60, scale: 0.95 });

      const titleEl = document.querySelector<HTMLElement>('.lobby-title');
      if (titleEl && isDesktop) {
        const titleChars = splitTextIntoChars(titleEl);
        gsap.set(titleChars, { autoAlpha: 0, y: 60 });

        ScrollTrigger.create({
          trigger: titleEl,
          start: 'top 85%',
          once: true,
          onEnter: () => {
            gsap.to('.lobby-header', { autoAlpha: 1, y: 0, duration: 0.4 });
            gsap.to(titleChars, {
              autoAlpha: 1,
              y: 0,
              stagger: 0.025,
              duration: 0.7,
              ease: 'power3.out',
            });
          },
        });
      } else {
        ScrollTrigger.create({
          trigger: '.lobby-header',
          start: 'top 90%',
          once: true,
          onEnter: () => {
            gsap.to('.lobby-header', { autoAlpha: 1, y: 0, duration: 0.5, ease: 'power2.out' });
          },
        });
      }

      ScrollTrigger.batch('.game-card', {
        start: 'top 92%',
        once: true,
        onEnter: (batch) =>
          gsap.to(batch, {
            autoAlpha: 1,
            y: 0,
            scale: 1,
            rotation: 0,
            stagger: { each: 0.12, from: 'start' },
            duration: 0.7,
            ease: 'power3.out',
            overwrite: true,
          }),
      });

      if (isDesktop) {
        // Hover tilt only (sin scrub rotation) — para no interferir con el 3D flip
        tilt3D('.game-card', { intensity: 6 });
      }
    });
  }

  function bootOnce() {
    initLobby();
  }

  document.addEventListener('DOMContentLoaded', bootOnce);
  document.addEventListener('astro:page-load', bootOnce);
</script>
