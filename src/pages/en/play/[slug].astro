---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import ArcadeMachine from '@components/portfolio/ArcadeMachine.astro';
import { games } from '@utils/games';

export const getStaticPaths: GetStaticPaths = async () => {
  return games.map((game) => ({
    params: { slug: game.slug },
    props: { game },
  }));
};

const { game } = Astro.props;
const lang = 'en';
---

<BaseLayout
  title={`${game.title} | Arcade | DevBlog`}
  description={game.description}
  lang={lang}
>
  <div class="max-w-5xl mx-auto px-6 py-12">
    <a
      href={`/${lang}/portfolio`}
      class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-neon-cyan transition-colors mb-8 group"
    >
      <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18"/>
      </svg>
      <span>Back to lobby</span>
    </a>

    <ArcadeMachine
      gameUrl={game.gameUrl}
      title={game.title}
      description={game.description}
      aspectRatio={game.aspectRatio}
    />

    <div class="mt-8 p-6 bg-[#111827]/60 rounded-xl border border-white/5">
      <h2 class="font-display text-xl font-bold text-white mb-2">{game.title}</h2>
      <p class="text-gray-400 text-sm">{game.description}</p>
      <div class="mt-4 flex flex-wrap gap-2">
        <span class="px-2 py-0.5 text-[10px] font-mono text-neon-cyan bg-neon-cyan/5 border border-neon-cyan/30 rounded">
          HTML5 Canvas
        </span>
        <span class="px-2 py-0.5 text-[10px] font-mono text-neon-purple bg-neon-purple/5 border border-neon-purple/30 rounded">
          JavaScript
        </span>
      </div>
    </div>
  </div>
</BaseLayout>
