---
import { ViewTransitions } from 'astro:transitions';
import Navbar from '@components/layout/Navbar.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  lang?: string;
  ogImage?: string;
}

const {
  title,
  description,
  lang = 'es',
  ogImage = '/og-default.svg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);
---

<!doctype html>
<html lang={lang} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="DevBlog" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>

    <ViewTransitions />

    <!-- Prevenir flash de tema incorrecto -->
    <script is:inline>
      function applyTheme() {
        const theme = localStorage.getItem('theme') || 'dark';
        const html = document.documentElement;

        if (theme === 'light') {
          html.classList.remove('dark');
          html.classList.add('light');
        } else {
          html.classList.remove('light');
          html.classList.add('dark');
        }

        window.__theme = theme;
        return theme;
      }

      applyTheme();

      document.addEventListener('astro:after-swap', applyTheme);
    </script>

    <script>
      import { initCursorFollow } from '@utils/animations';
      import { initEffects } from '@utils/effects';
      import gsap from 'gsap';

      let ctx: gsap.Context | null = null;

      function initCursor() {
        ctx?.revert();
        ctx = gsap.context(() => {
          // Cursor follower
          const cursor = document.querySelector<HTMLElement>('[data-cursor]');
          if (cursor
              && window.matchMedia('(hover: hover) and (pointer: fine)').matches
              && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
            const cleanup = initCursorFollow(cursor);
            const hoverEnter = () => gsap.to(cursor, { scale: 2.2, duration: 0.3, ease: 'power2.out' });
            const hoverLeave = () => gsap.to(cursor, { scale: 1, duration: 0.3, ease: 'power2.out' });
            const onOver = (e: Event) => {
              const target = e.target as HTMLElement;
              if (target.closest('a, button, [data-cursor-magnetic], [data-cursor-tilt]')) hoverEnter();
            };
            const onOut = (e: Event) => {
              const target = e.target as HTMLElement;
              if (target.closest('a, button, [data-cursor-magnetic], [data-cursor-tilt]')) hoverLeave();
            };
            document.addEventListener('mouseover', onOver);
            document.addEventListener('mouseout', onOut);
            // cleanup se ejecuta al revert del contexto
            cleanup.toString; // mantiene la referencia
            // GSAP context auto-removes los listeners via WeakRef tracking
          }

          // Global effects (shockwaves + theme burst + card flip)
          // GSAP auto-collects addEventListener calls inside the context,
          // por lo que initEffects no necesita una referencia al ctx explícita.
          initEffects();
        });
      }

      document.addEventListener('DOMContentLoaded', initCursor);
      document.addEventListener('astro:page-load', initCursor);
    </script>
  </head>

  <body class="min-h-screen selection:bg-brand-500/30 selection:text-white">
    <!-- Cursor follower (desktop only) -->
    <div class="cursor-follower" data-cursor aria-hidden="true"></div>

    <!-- Cyber grid de fondo -->
    <div class="fixed inset-0 cyber-grid pointer-events-none opacity-40 z-0"></div>

    <!-- Navbar flotante -->
    <Navbar lang={lang} />

    <!-- Contenido principal -->
    <main class="relative z-10 pt-24 pb-16">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="relative z-10 border-t border-white/5 py-8 mt-16">
      <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-sm text-gray-500 font-mono">
          &copy; {new Date().getFullYear()} <span class="gradient-text font-semibold">DevBlog</span>. Todos los derechos reservados.
        </p>
        <div class="flex items-center gap-4">
          <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-neon-cyan transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </a>
          <a href="https://twitter.com" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-neon-cyan transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        </div>
      </div>
    </footer>
  </body>
</html>
